# ──────────────────────────────────────────────────────────────
#  STEP 1: Choose your LLM provider
#  Options: grok | gemini | anthropic
# ──────────────────────────────────────────────────────────────
LLM_PROVIDER=grok

# ──────────────────────────────────────────────────────────────
#  STEP 2: Set the API key for your chosen provider
# ──────────────────────────────────────────────────────────────

# GROK (xAI) — Free tier available
# Get key: https://console.x.ai
GROK_API_KEY=xai-YOUR_KEY_HERE

# GEMINI (Google) — Free forever, no credit card  ← RECOMMENDED
# Get key: https://aistudio.google.com → "Get API Key"
GEMINI_API_KEY=AIza-YOUR_KEY_HERE

# ANTHROPIC — $5 free credits on signup
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ──────────────────────────────────────────────────────────────
#  OPTIONAL: Override model, Langfuse tracing
# ──────────────────────────────────────────────────────────────
# LLM_MODEL=grok-3-mini
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
